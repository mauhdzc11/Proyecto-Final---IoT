# ProyectoFinal-IoT — variables de entorno del dashboard
# Copia este archivo como .env y rellena con tus datos de HiveMQ Cloud.
# El navegador habla MQTT sobre WebSocket seguro (WSS), normalmente puerto 8884.

VITE_MQTT_HOST=TU_BROKER.s1.eu.hivemq.cloud
VITE_MQTT_PORT=8884
VITE_MQTT_USER=CAMBIAR_USUARIO
VITE_MQTT_PASS=CAMBIAR_PASSWORD

# Identidad del nodo y base del árbol de tópicos (deben coincidir con el firmware)
VITE_DEVICE_ID=node1
VITE_TOPIC_ROOT=escom/iot/6cm3
